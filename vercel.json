{
    "version": 2,
    "builds": [
          {
                  "src": "dist/index.js",
                  "use": "@vercel/node"
          }
    ],
    "routes": [
          {
                  "src": "/.well-known/mcp.json",
                  "dest": "/.well-known/mcp.json"
          },
          {
                  "src": "/(.*)",
                  "dest": "dist/index.js"
          }
    ]
}
